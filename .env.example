# Optional RAG answer-chain LLM environment fallback.
# Preferred local setup: uv run python llm_config_demo.py
# Copy this file to .env only when you want environment-based deployment config.
# Do not commit real API keys.

# OpenAI-compatible providers: OpenAI, DeepSeek, siliconflow, OneAPI, OpenRouter, etc.
RAG_LLM_PROVIDER=openai-compatible
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_BASE_URL=https://api.openai.com/v1
RAG_LLM_API_KEY=your_api_key_here
RAG_LLM_TEMPERATURE=0.2
RAG_LLM_TIMEOUT=60

# Ollama local chat model example:
# RAG_LLM_PROVIDER=ollama
# RAG_LLM_MODEL=qwen2.5:7b
# RAG_LLM_BASE_URL=http://localhost:11434
# RAG_LLM_API_KEY=
